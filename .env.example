# ─────────────────────────────────────────────────
# SprintFlow Enterprise — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────

# ─── Authentication ──────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                                    # Generate: openssl rand -base64 32

# ─── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sprintflow?schema=public

# ─── Email (Resend / SMTP) ───────────────────────
ADMIN_EMAIL=admin@example.com
RESEND_API_KEY=                                     # https://resend.com/api-keys
EMAIL_PROVIDER=resend                               # resend | logger (dev only)
EMAIL_FROM=onboarding@resend.dev

# ─── AI Providers (optional) ─────────────────────
OPENAI_API_KEY=                                     # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=                                  # https://console.anthropic.com/keys
GOOGLE_AI_API_KEY=                                  # https://aistudio.google.com/apikey
OLLAMA_BASE_URL=http://localhost:11434              # Default for local Ollama

# ─── Storage (optional) ──────────────────────────
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# ─── Monitoring / Retention ──────────────────────
AUDIT_RETENTION_DAYS=90                             # 30 | 90 | 180 | 365 | forever
LOG_LEVEL=info                                      # trace | debug | info | warn | error
